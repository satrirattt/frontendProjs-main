                        <th>Promotion Discount %</th>
                    </tr>
                </thead>
                <tbody>
                    <% payments.forEach(payment => { %>
                        <tr>
                            <td><%= payment.Order_ID %></td>
                            <td><%= payment.Customer_Name %></td>
                            <td><%= payment.Customer_address %></td>
                            <td><%= payment.Customer_Phonenumber %></td>
                            <td><%= payment.Order_Product_Name %></td>
                            <td><%= payment.Order_Quantity %></td>
                            <td><%= payment.TotalPrice %></td>
                            <td><%= payment.Order_Datetime %></td>
                            <td><%= payment.Payment_Type %></td>
                            <td><%= payment.Promotion_Discount ? payment.Promotion_Discount + '%' : '-' %></td>
                        </tr>
                    <% }); %>
                </tbody>
